---
// MoE token routing and aggregation diagram
---
<div class="svg-container bg-white border border-gray-200 shadow-inner">
    <svg width="860" height="460" viewBox="0 0 860 460" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="MoE routing diagram">
        <defs>
            <marker id="arrow-moe" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
                <polygon points="0 0, 10 3.5, 0 7" fill="#475569"/>
            </marker>
        </defs>

        <rect x="20" y="20" width="820" height="420" rx="18" fill="#f8fafc" stroke="#cbd5e1"/>
        <text x="430" y="52" text-anchor="middle" font-size="22" font-weight="700" fill="#0f172a">MoE Layer: Router -> Top-k Experts -> Weighted Merge</text>

        <g transform="translate(56, 100)">
            <rect x="0" y="0" width="140" height="238" rx="14" fill="#ecfeff" stroke="#06b6d4" stroke-width="2"/>
            <text x="70" y="28" text-anchor="middle" font-size="14" font-weight="700" fill="#0e7490">Input Tokens</text>

            <rect x="20" y="50" width="100" height="34" rx="8" fill="#ffffff" stroke="#0ea5e9"/>
            <text x="70" y="72" text-anchor="middle" font-size="12" fill="#0369a1">token t1</text>

            <rect x="20" y="96" width="100" height="34" rx="8" fill="#ffffff" stroke="#0ea5e9"/>
            <text x="70" y="118" text-anchor="middle" font-size="12" fill="#0369a1">token t2</text>

            <rect x="20" y="142" width="100" height="34" rx="8" fill="#ffffff" stroke="#0ea5e9"/>
            <text x="70" y="164" text-anchor="middle" font-size="12" fill="#0369a1">token t3</text>

            <rect x="20" y="188" width="100" height="34" rx="8" fill="#ffffff" stroke="#0ea5e9"/>
            <text x="70" y="210" text-anchor="middle" font-size="12" fill="#0369a1">token ...</text>
        </g>

        <g transform="translate(250, 110)">
            <rect x="0" y="0" width="170" height="220" rx="14" fill="#fef3c7" stroke="#f59e0b" stroke-width="2"/>
            <text x="85" y="30" text-anchor="middle" font-size="14" font-weight="700" fill="#92400e">Router</text>
            <text x="85" y="52" text-anchor="middle" font-size="12" fill="#92400e">Linear + Softmax</text>

            <rect x="20" y="74" width="130" height="34" rx="8" fill="#ffffff" stroke="#f59e0b"/>
            <text x="85" y="96" text-anchor="middle" font-size="11" fill="#78350f">p(e|t1)=[0.52,0.03,...]</text>

            <rect x="20" y="118" width="130" height="34" rx="8" fill="#ffffff" stroke="#f59e0b"/>
            <text x="85" y="140" text-anchor="middle" font-size="11" fill="#78350f">Top-k(t1): e1, e4</text>

            <rect x="20" y="162" width="130" height="34" rx="8" fill="#ffffff" stroke="#f59e0b"/>
            <text x="85" y="184" text-anchor="middle" font-size="11" fill="#78350f">Top-k(t2): e2, e7</text>
        </g>

        <g transform="translate(478, 88)">
            <rect x="0" y="0" width="310" height="262" rx="14" fill="#eef2ff" stroke="#6366f1" stroke-width="2"/>
            <text x="155" y="28" text-anchor="middle" font-size="14" font-weight="700" fill="#3730a3">Experts (FFN blocks)</text>

            <rect x="18" y="48" width="84" height="48" rx="8" fill="#ffffff" stroke="#6366f1"/>
            <text x="60" y="78" text-anchor="middle" font-size="12" fill="#4338ca">Expert 1</text>

            <rect x="114" y="48" width="84" height="48" rx="8" fill="#ffffff" stroke="#6366f1"/>
            <text x="156" y="78" text-anchor="middle" font-size="12" fill="#4338ca">Expert 2</text>

            <rect x="210" y="48" width="84" height="48" rx="8" fill="#ffffff" stroke="#6366f1"/>
            <text x="252" y="78" text-anchor="middle" font-size="12" fill="#4338ca">Expert 3</text>

            <rect x="18" y="116" width="84" height="48" rx="8" fill="#ffffff" stroke="#6366f1"/>
            <text x="60" y="146" text-anchor="middle" font-size="12" fill="#4338ca">Expert 4</text>

            <rect x="114" y="116" width="84" height="48" rx="8" fill="#ffffff" stroke="#6366f1"/>
            <text x="156" y="146" text-anchor="middle" font-size="12" fill="#4338ca">Expert 5</text>

            <rect x="210" y="116" width="84" height="48" rx="8" fill="#ffffff" stroke="#6366f1"/>
            <text x="252" y="146" text-anchor="middle" font-size="12" fill="#4338ca">Expert 6</text>

            <rect x="18" y="184" width="276" height="56" rx="8" fill="#ffffff" stroke="#94a3b8" stroke-dasharray="4 4"/>
            <text x="156" y="206" text-anchor="middle" font-size="12" fill="#334155">Only selected experts run per token</text>
            <text x="156" y="224" text-anchor="middle" font-size="12" fill="#334155">(sparse activation)</text>
        </g>

        <g transform="translate(338, 354)">
            <rect x="0" y="0" width="220" height="64" rx="12" fill="#dcfce7" stroke="#16a34a" stroke-width="2"/>
            <text x="110" y="28" text-anchor="middle" font-size="13" font-weight="700" fill="#166534">Weighted Merge</text>
            <text x="110" y="46" text-anchor="middle" font-size="12" fill="#166534">y = sum p_i * Expert_i(x)</text>
        </g>

        <path d="M196 219 L250 219" stroke="#475569" stroke-width="2" marker-end="url(#arrow-moe)"/>
        <path d="M420 176 L478 132" stroke="#475569" stroke-width="2" marker-end="url(#arrow-moe)"/>
        <path d="M420 222 L478 178" stroke="#475569" stroke-width="2" marker-end="url(#arrow-moe)"/>
        <path d="M420 254 L478 250" stroke="#475569" stroke-width="2" marker-end="url(#arrow-moe)"/>

        <path d="M540 350 L540 354" stroke="#475569" stroke-width="2" marker-end="url(#arrow-moe)"/>
        <path d="M620 350 L558 354" stroke="#475569" stroke-width="2" marker-end="url(#arrow-moe)"/>

        <text x="260" y="404" font-size="12" fill="#64748b">Load-balancing loss keeps token assignment even.</text>
    </svg>
</div>
