---
// GRPO 训练流程示意图
---

<div class="svg-container">
    <svg width="900" height="380" viewBox="0 0 900 380" xmlns="http://www.w3.org/2000/svg">
        <defs>
            <linearGradient id="grpoPolicyGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#0369a1;stop-opacity:0.25" />
                <stop offset="100%" style="stop-color:#0369a1;stop-opacity:0.1" />
            </linearGradient>
            <linearGradient id="grpoGroupGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#0ea5e9;stop-opacity:0.25" />
                <stop offset="100%" style="stop-color:#0ea5e9;stop-opacity:0.1" />
            </linearGradient>
            <linearGradient id="grpoRewardGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#10b981;stop-opacity:0.25" />
                <stop offset="100%" style="stop-color:#10b981;stop-opacity:0.1" />
            </linearGradient>
            <filter id="grpoShadow">
                <feGaussianBlur in="SourceAlpha" stdDeviation="3"/>
                <feOffset dx="0" dy="2" result="offsetblur"/>
                <feComponentTransfer>
                    <feFuncA type="linear" slope="0.25"/>
                </feComponentTransfer>
                <feMerge>
                    <feMergeNode/>
                    <feMergeNode in="SourceGraphic"/>
                </feMerge>
            </filter>
            <marker id="grpoArrow" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
                <polygon points="0 0, 10 3, 0 6" fill="#1f2937" />
            </marker>
        </defs>

        <text x="450" y="32" text-anchor="middle" font-size="22" font-weight="bold" fill="#1e293b">GRPO 训练循环</text>
        <text x="450" y="56" text-anchor="middle" font-size="14" fill="#64748b">无需 Critic 模型，利用组内相对评分计算优势</text>

        <!-- Current Policy -->
        <g transform="translate(60, 120)">
            <rect width="180" height="90" rx="16" fill="url(#grpoPolicyGrad)" stroke="#0369a1" stroke-width="2" filter="url(#grpoShadow)"/>
            <text x="90" y="40" text-anchor="middle" font-size="16" font-weight="bold" fill="#0369a1">当前策略 π</text>
            <text x="90" y="62" text-anchor="middle" font-size="13" fill="#334155">Actor Only</text>
        </g>

        <!-- Group Sampling -->
        <g transform="translate(300, 100)">
            <rect width="180" height="130" rx="16" fill="url(#grpoGroupGrad)" stroke="#0ea5e9" stroke-width="2" filter="url(#grpoShadow)"/>
            <text x="90" y="35" text-anchor="middle" font-size="15" font-weight="bold" fill="#0ea5e9">组内采样 (G 个)</text>
            <rect x="20" y="50" width="140" height="15" rx="4" fill="#fff" opacity="0.8" stroke="#0ea5e9" stroke-width="1"/>
            <rect x="20" y="70" width="140" height="15" rx="4" fill="#fff" opacity="0.8" stroke="#0ea5e9" stroke-width="1"/>
            <rect x="20" y="90" width="140" height="15" rx="4" fill="#fff" opacity="0.8" stroke="#0ea5e9" stroke-width="1"/>
            <text x="90" y="118" text-anchor="middle" font-size="11" fill="#64748b">...</text>
        </g>

        <!-- Reward Functions -->
        <g transform="translate(540, 100)">
            <rect width="180" height="130" rx="16" fill="url(#grpoRewardGrad)" stroke="#10b981" stroke-width="2" filter="url(#grpoShadow)"/>
            <text x="90" y="35" text-anchor="middle" font-size="15" font-weight="bold" fill="#10b981">奖励函数 / Verifier</text>
            <text x="90" y="70" text-anchor="middle" font-size="12" fill="#065f46">Reward 1: +1.0</text>
            <text x="90" y="95" text-anchor="middle" font-size="12" fill="#065f46">Reward 2: -0.5</text>
            <text x="90" y="115" text-anchor="middle" font-size="11" fill="#64748b">...</text>
        </g>

        <!-- Advantage Calculation -->
        <g transform="translate(300, 270)">
            <rect width="420" height="70" rx="18" fill="#f8fafc" stroke="#64748b" stroke-width="2" stroke-dasharray="4,4"/>
            <text x="210" y="42" text-anchor="middle" font-size="16" font-weight="bold" fill="#334155">优势估计：A_i = (r_i - mean(r)) / std(r)</text>
        </g>

        <!-- Arrows -->
        <path d="M 240 165 L 300 165" stroke="#1f2937" stroke-width="2" fill="none" marker-end="url(#grpoArrow)"/>
        <path d="M 480 165 L 540 165" stroke="#1f2937" stroke-width="2" fill="none" marker-end="url(#grpoArrow)"/>
        <path d="M 630 230 L 630 270" stroke="#1f2937" stroke-width="2" fill="none" marker-end="url(#grpoArrow)"/>
        
        <path d="M 300 305 L 150 305 L 150 210" stroke="#64748b" stroke-width="2" stroke-dasharray="6,6" fill="none" marker-end="url(#grpoArrow)"/>
        <text x="150" y="260" text-anchor="middle" font-size="12" fill="#64748b">策略更新</text>
    </svg>
</div>
