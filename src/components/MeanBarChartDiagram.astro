---
// Animated bar chart showing how each mean responds to an outlier
// Dataset: [2, 3, 4, 5, 100]
const data = [2, 3, 4, 5, 100];
const n = data.length;
const am = data.reduce((s, v) => s + v, 0) / n;                          // 22.8
const gm = Math.pow(data.reduce((p, v) => p * v, 1), 1 / n);             // ~6.79
const hm = n / data.reduce((s, v) => s + 1 / v, 0);                       // ~4.03
const med = 4;                                                              // median
const rms = Math.sqrt(data.reduce((s, v) => s + v * v, 0) / n);           // ~44.9

const means = [
    { name: '调和平均', short: 'HM', value: hm, color: '#ef4444' },
    { name: '中位数', short: 'Med', value: med, color: '#8b5cf6' },
    { name: '几何平均', short: 'GM', value: gm, color: '#f59e0b' },
    { name: '算术平均', short: 'AM', value: am, color: '#0f766e' },
    { name: '均方根', short: 'RMS', value: rms, color: '#3b82f6' },
];

const maxVal = 50; // cap display for readability
const barWidth = 70;
const barGap = 30;
const chartLeft = 110;
const chartBottom = 230;
const chartHeight = 160;
---

<div class="svg-container">
    <svg viewBox="0 0 680 320" role="img" aria-label="各类平均数对离群值的响应" class="w-full max-w-3xl">
        <defs>
            {means.map(m => (
                <linearGradient id={`bar-${m.short}`} x1="0" x2="0" y1="1" y2="0">
                    <stop offset="0%" stop-color={m.color} stop-opacity="0.7" />
                    <stop offset="100%" stop-color={m.color} stop-opacity="1" />
                </linearGradient>
            ))}
        </defs>

        <text x="340" y="28" text-anchor="middle" font-size="15" font-weight="700" fill="var(--ink)">
            数据集 [2, 3, 4, 5, 100]：谁对离群值最敏感？
        </text>

        <!-- Y axis -->
        <line x1={chartLeft - 10} y1={chartBottom - chartHeight} x2={chartLeft - 10} y2={chartBottom + 2} stroke="#cbd5e1" stroke-width="1.5" />
        {[0, 10, 20, 30, 40, 50].map(v => {
            const y = chartBottom - (v / maxVal) * chartHeight;
            return (
                <g>
                    <line x1={chartLeft - 15} y1={y} x2={chartLeft - 10} y2={y} stroke="#94a3b8" stroke-width="1" />
                    <text x={chartLeft - 20} y={y + 4} text-anchor="end" font-size="10" fill="#94a3b8">{v}</text>
                    <line x1={chartLeft - 10} y1={y} x2={chartLeft + 500} y2={y} stroke="#e2e8f0" stroke-width="0.5" stroke-dasharray="4 4" />
                </g>
            );
        })}

        <!-- Bars -->
        {means.map((m, i) => {
            const x = chartLeft + i * (barWidth + barGap);
            const displayVal = Math.min(m.value, maxVal);
            const barH = (displayVal / maxVal) * chartHeight;
            const y = chartBottom - barH;
            const isClipped = m.value > maxVal;
            return (
                <g>
                    <rect x={x} y={chartBottom} width={barWidth} height="0" rx="8" fill={`url(#bar-${m.short})`}>
                        <animate attributeName="y" from={chartBottom} to={y} dur="0.8s" fill="freeze" begin={`${i * 0.15}s`} calcMode="spline" keySplines="0.33 1 0.68 1" />
                        <animate attributeName="height" from="0" to={barH} dur="0.8s" fill="freeze" begin={`${i * 0.15}s`} calcMode="spline" keySplines="0.33 1 0.68 1" />
                    </rect>
                    {/* Value label */}
                    <text x={x + barWidth / 2} y={y - 8} text-anchor="middle" font-size="13" font-weight="700" fill={m.color} opacity="0">
                        {m.value.toFixed(1)}{isClipped ? '↑' : ''}
                        <animate attributeName="opacity" from="0" to="1" dur="0.3s" fill="freeze" begin={`${i * 0.15 + 0.6}s`} />
                    </text>
                    {/* Name label */}
                    <text x={x + barWidth / 2} y={chartBottom + 18} text-anchor="middle" font-size="11" font-weight="600" fill={m.color}>
                        {m.short}
                    </text>
                    <text x={x + barWidth / 2} y={chartBottom + 33} text-anchor="middle" font-size="10" fill="#64748b">
                        {m.name}
                    </text>
                    {/* Clipped indicator */}
                    {isClipped && (
                        <g>
                            <line x1={x + 10} y1={y + 3} x2={x + barWidth - 10} y2={y + 3} stroke="white" stroke-width="2" stroke-dasharray="3 3" />
                            <text x={x + barWidth / 2} y={y + 15} text-anchor="middle" font-size="9" fill="white" font-weight="600">截断</text>
                        </g>
                    )}
                </g>
            );
        })}

        <!-- Insight annotation -->
        <g transform="translate(120, 275)">
            <rect x="0" y="0" width="440" height="36" rx="12" fill="white" stroke="#e2e8f0" />
            <text x="220" y="24" text-anchor="middle" font-size="12" fill="#64748b">
                💡 离群值 100 把 AM 拉到 22.8，RMS 更夸张达 44.9；HM 仅 4.0，几乎不受影响
            </text>
        </g>
    </svg>
</div>
