---
// Interactive-style SVG showing weighted mean as a balance/lever
// Scores: [90, 70, 85] with weights [50%, 30%, 20%]
const items = [
    { label: '期末考试', score: 90, weight: 0.5, color: '#0f766e' },
    { label: '平时作业', score: 70, weight: 0.3, color: '#f59e0b' },
    { label: '课堂参与', score: 85, weight: 0.2, color: '#3b82f6' },
];
const wm = items.reduce((s, it) => s + it.score * it.weight, 0); // 83
---

<div class="svg-container">
    <svg viewBox="0 0 700 300" role="img" aria-label="加权平均数天平示意图" class="w-full max-w-3xl">
        <defs>
            <filter id="wmShadow">
                <feDropShadow dx="0" dy="2" stdDeviation="3" flood-opacity="0.12" />
            </filter>
        </defs>

        <text x="350" y="28" text-anchor="middle" font-size="15" font-weight="700" fill="var(--ink)">
            加权平均 = 各项 × 权重 之和
        </text>

        <!-- Fulcrum / pivot -->
        <polygon points="350,200 335,230 365,230" fill="#94a3b8" opacity="0.6" />
        <text x="350" y="248" text-anchor="middle" font-size="13" font-weight="700" fill="var(--accent-strong)">
            加权平均 = {wm}
        </text>

        <!-- Lever bar -->
        <line x1="80" y1="200" x2="620" y2="200" stroke="#475569" stroke-width="3" stroke-linecap="round" />

        <!-- Weight blocks on lever -->
        {items.map((it, i) => {
            const x = 130 + i * 200;
            const blockH = it.weight * 120;  // visual height proportional to weight
            const y = 200 - blockH;
            return (
                <g>
                    {/* Block */}
                    <rect x={x - 40} y={200} width="80" height="0" rx="10" fill={it.color} filter="url(#wmShadow)" opacity="0.9">
                        <animate attributeName="y" from="200" to={y} dur="0.7s" fill="freeze" begin={`${i * 0.25}s`} calcMode="spline" keySplines="0.33 1 0.68 1" />
                        <animate attributeName="height" from="0" to={blockH} dur="0.7s" fill="freeze" begin={`${i * 0.25}s`} calcMode="spline" keySplines="0.33 1 0.68 1" />
                    </rect>
                    {/* Score inside block */}
                    <text x={x} y={y + blockH / 2 + 5} text-anchor="middle" font-size="16" font-weight="700" fill="white" opacity="0">
                        {it.score}
                        <animate attributeName="opacity" from="0" to="1" dur="0.3s" fill="freeze" begin={`${i * 0.25 + 0.5}s`} />
                    </text>
                    {/* Weight label */}
                    <text x={x} y={y - 10} text-anchor="middle" font-size="12" font-weight="600" fill={it.color} opacity="0">
                        ×{(it.weight * 100).toFixed(0)}%
                        <animate attributeName="opacity" from="0" to="1" dur="0.3s" fill="freeze" begin={`${i * 0.25 + 0.5}s`} />
                    </text>
                    {/* Item label */}
                    <text x={x} y="270" text-anchor="middle" font-size="12" fill="#475569">{it.label}</text>
                </g>
            );
        })}

        <!-- Calculation -->
        <text x="350" y="295" text-anchor="middle" font-size="11" fill="#94a3b8">
            90×0.5 + 70×0.3 + 85×0.2 = 45 + 21 + 17 = 83
        </text>
    </svg>
</div>
