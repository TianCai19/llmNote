const createdAt = todayYmd();

export const meta = {
    number: '24',
    title: 'On-Policy RL：LLM 训练的关键转折点',
    description: '深入理解大语言模型中的 On-Policy 强化学习：从策略梯度、PPO、GRPO 到最新的 Dr. GRPO 与 DAPO 算法演进',
